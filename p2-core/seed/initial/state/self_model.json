    "session_action_loop_v1"
  ],
  "capabilities": [
    "single_file_full_replacement",
    "candidate_validation",
    "promotion",
    "reset_to_initial_state",
    "dashboard_notification",
    "history_aware_meta_diagnosis",
    "meta_search_mode_switching",
